# Copy this file to `.env` and fill in the required values before running agents.

# Required for your LiteLLM-backed model provider.
OPENAI_API_KEY=

# Required for web-search-capable agents.
BRAVE_API_KEY=

# LiteLLM model selection.
LITELLM_MODEL=openai/gpt-4o-mini
LITELLM_PROVIDER=openai
LITELLM_TEMPERATURE=0.2
LITELLM_DROP_PARAMS=false
LITELLM_SSL_VERIFY=true

# ADK runtime defaults.
ADK_MAX_LLM_CALLS=0
ADK_DEBUG=false
ADK_TRACE=true

# Brave Search defaults.
BRAVE_SEARCH_COUNTRY=us
BRAVE_SEARCH_LANG=en
BRAVE_VERIFY=true
BRAVE_ALLOW_INSECURE_FALLBACK=false

# Only set LITELLM_SSL_VERIFY=false as a temporary local workaround for
# certificate issues in a controlled dev environment.
